{
  "name": "downtowndry-data-enrichment",
  "version": "1.0.0",
  "description": "Automated venue verification and data enrichment for DowntownDry",
  "main": "scripts/01_extract_venues.js",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "extract": "node scripts/01_extract_venues.js",
    "verify": "node scripts/02_primary_verification.js",
    "secondary": "node scripts/03_secondary_verification.js",
    "enrich": "node scripts/04_data_enrichment.js",
    "review": "node scripts/05_final_verification.js",
    "deploy": "node scripts/06_database_update.js",
    "test:city": "node scripts/test-single-city.js",
    "verify:nonprod": "node scripts/verify-non-production-cities.js",
    "discover:city": "node scripts/discover-new-venues.js",
    "discover:all": "node scripts/discover-all-cities.js",
    "apply:dry-run": "node scripts/apply-verification-results.js --dry-run",
    "apply:live": "node scripts/apply-verification-results.js --apply",
    "enrich:dry-run": "node scripts/enrich-venue-data.js --dry-run",
    "enrich:auto": "node scripts/enrich-venue-data.js --auto",
    "enrich:review": "node scripts/enrich-venue-data.js --review",
    "city-images:find": "node scripts/find-city-images.js --dry-run",
    "city-images:apply": "node scripts/find-city-images.js --apply",
    "city-images:featured": "node scripts/find-city-images.js --featured-only --dry-run"
  },
  "keywords": [
    "venue",
    "verification",
    "data-enrichment",
    "automation"
  ],
  "author": "Adam - DowntownDry",
  "license": "ISC",
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "^5.1.5",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.101.1",
    "@vercel/analytics": "^2.0.1",
    "astro": "^5.18.1",
    "axios": "^1.14.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^17.4.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
